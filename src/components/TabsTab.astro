---
/**
 * TabsTab Component
 *
 * @description A tab within a Tabs component
 */

interface Props {
  /**
   * Additional classes to apply to the tab
   */
  class?: string;
  /**
   * Unique identifier for the tab
   */
  id: string;
  /**
   * ID of the panel this tab controls
   */
  controls: string;
  /**
   * Whether this tab is currently selected
   * @default false
   */
  selected?: boolean;
  /**
   * HTML attributes to spread on the tab
   */
  [key: string]: string | number | boolean | undefined;
}

const { class: className, id, controls, selected = false, ...rest } = Astro.props;
---

<button
  id={id}
  role="tab"
  class:list={["tab", className]}
  aria-controls={controls}
  aria-selected={selected}
  tabindex={selected ? 0 : -1}
  {...rest}
>
  <slot />
</button>

<style>
  :where(.tab) {
    border: 0;
    border-bottom: 2px solid var(--color-white-92);
    background-color: transparent;
    padding: var(--size-gap-small, 0.75rem) var(--size-gap-large, 1.5rem);
    font: inherit;
    font-weight: 700;
    color: var(--color-default-text);
    cursor: pointer;
    white-space: normal;
    position: relative;
    word-break: normal;
    width: 100%;
    text-align: center;
    box-shadow: none;
    margin-bottom: -1px;
  }

  :where(.tab[aria-selected="true"]) {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  :where(.tab:hover),
  :where(.tab:focus-visible) {
    color: var(--color-primary);
    outline: none;
    box-shadow: none;
  }
</style>
