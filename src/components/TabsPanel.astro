---
/**
 * TabsPanel Component
 *
 * @description A panel within a Tabs component
 */

interface Props {
  /**
   * Additional classes to apply to the panel
   */
  class?: string;
  /**
   * Unique identifier for the panel
   */
  id: string;
  /**
   * ID of the tab that labels this panel
   */
  labelledby: string;
  /**
   * Whether this panel is currently selected
   * @default false
   */
  selected?: boolean;
  /**
   * HTML attributes to spread on the panel
   */
  [key: string]: string | number | boolean | undefined;
}

const { class: className, id, labelledby, selected = false, ...rest } = Astro.props;
---

<div
  class:list={["tab-panel", className]}
  role="tabpanel"
  id={id}
  aria-labelledby={labelledby}
  aria-hidden={!selected}
  {...rest}
>
  <div class="tab-panel__heading">
    <slot name="heading" />
  </div>

  <div class="tab-panel__body">
    <slot name="body" />
  </div>

  <div class="tab-panel__image">
    <slot name="image" />
  </div>
</div>

<style>
  :where(.tab-panel) {
    display: none;
    height: 20rem;
    padding: var(--size-gap-large);
    gap: var(--size-gap-large, 1.5rem);
    background-color: var(--color-white-97);
    border-radius: 0 0 var(--size-border-radius-large) var(--size-border-radius-large);
    color: inherit;
    grid-template-columns: minmax(0, 1fr) minmax(120px, 240px);
    grid-template-rows: auto minmax(0, 1fr);
    grid-template-areas:
      "heading heading"
      "body image";
    overflow: hidden;
  }

  :where(.tab-panel[aria-hidden="false"]) {
    display: grid;
  }

  :where(.tab-panel__heading) {
    grid-area: heading;
    font-weight: 700;
  }

  :where(.tab-panel__body) {
    grid-area: body;
  }

  :where(.tab-panel__image) {
    grid-area: image;
    min-width: 0;
    min-height: 0;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    overflow: hidden;
  }

  :where(.tab-panel__image) :global(img) {
    display: block;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    :where(.tab-panel) {
      height: auto;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto minmax(160px, auto);
      grid-template-areas:
        "heading"
        "body"
        "image";
    }

    :where(.tab-panel__body) {
      overflow: visible;
    }

    :where(.tab-panel__image) {
      justify-content: center;
      align-items: flex-start;
    }

    :where(.tab-panel__image) :global(img) {
      max-width: 100%;
      height: auto;
    }
  }
</style>
