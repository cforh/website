<blockquote>
  <slot />
</blockquote>

<style>
  blockquote {
    position: relative;
    text-align: justify;
    margin: 0;
    padding: 2em;
    --quote-size: 5rem;

    &::before,
    &::after {
      position: absolute;
      font-size: var(--quote-size);
      line-height: 0;
      color: var(--color-primary);
    }

    &::before {
      content: "“";
      inset-block-end: calc(100% - 0.4em);
      inset-inline-end: calc(100% - 0.2em);
    }

    &::after {
      content: "”";
      inset-block-start: calc(100% + 0.16em);
      inset-inline-start: calc(100% - 0.2em);
    }
  }
</style>
