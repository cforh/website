---
type Props = {
  class?: string;
};

const { class: className } = Astro.props;
---

<div class:list={["feature-list", className]}>
  <slot>
    <p>Set feature cards as children!</p>
  </slot>
</div>

<style>
  .feature-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 16rem;
    gap: var(--size-gap-small);
  }

  .feature-list > :global(*) {
    min-width: 0;
    min-height: 0;
  }

  @media (max-width: 800px) {
    .feature-list {
      display: flex;
      flex-direction: column;
      gap: var(--size-gap-tiny);
    }
  }
</style>
