---
import type { ImageMetadata } from "astro";

type Props = {
  title: string;
  tagline?: string;
  spotlight?: { alt: string; image: ImageMetadata };
  layout?: "column" | "row";
  className?: string;
};

const { title, tagline, spotlight, layout = "column", className } = Astro.props;
---

<div
  class={`flip-card ${layout} ${(spotlight ? "has-image" : "no-image")} ${className}`}
  tabindex="0"
  role="button"
  aria-pressed="false"
>
  <div class="front">
    <div class="card-image">
      {spotlight && <img src={spotlight.image.src} alt={spotlight.alt} />}
    </div>

    <div class="content">
      <h3>{title}</h3>
      {tagline && <p>{tagline}</p>}
    </div>
  </div>

  <div class="back">
    <h3>{title}</h3>
    <slot />
  </div>
</div>

<style>
  .flip-card {
    display: grid;
    justify-items: center;
    perspective: 1000px;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .front,
  .back {
    width: 100%;
    height: 100%;
    grid-area: 1 / 1;
    backface-visibility: hidden;
    transition: transform 0.6s;
    padding: var(--size-gap);
    border-radius: var(--size-border-radius-large);
    border: var(--border-massive);
    box-sizing: border-box;
    overflow: hidden;
    align-items: center;
    justify-content: center;
  }

  .front {
    background-color: var(--color-white-97);
    display: flex;
    gap: var(--size-gap);
  }

  .back {
    background-color: var(--color-primary);
    color: var(--color-white);
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-y: auto;
  }

  .flip-card.column .front {
    flex-direction: column;
  }

  .flip-card.row .front {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .flip-card.no-image .front {
    flex-direction: column;
  }

  .card-image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  img {
    border-radius: var(--size-border-radius-small);
    height: 100%;
  }

  .flip-card.column.has-image img {
    width: 100%;
  }

  .flip-card.row.has-image img {
    object-fit: contain;
  }

  .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .content h3 {
    margin: 0;
  }

  .flip-card.column .content {
    width: 100%;
    text-align: center;
  }

  .flip-card.row .content {
    width: 100%;
    text-align: left;
  }

  @media (hover: hover) {
    .flip-card:hover .front {
      transform: rotateY(180deg);
    }

    .flip-card:hover .back {
      transform: rotateY(360deg);
    }
  }

  .flip-card.flipped .front {
    transform: rotateY(180deg);
  }

  .flip-card.flipped .back {
    transform: rotateY(360deg);
  }

  @media (max-width: 800px) {
    .front {
      padding: 0;
    }

    .flip-card.row .front {
      display: flex;
      flex-direction: column;
    }

    .flip-card.row .content {
      text-align: center;
    }
  }
</style>

<script>
  if (window.matchMedia("(hover: none)").matches) {
    document.querySelectorAll(".flip-card").forEach((card) => {
      card.addEventListener("click", () => card.classList.toggle("flipped"));
    });
  }
</script>
