---
import type { ImageMetadata } from "astro";

type Props = {
  title: string;
  spotlight: { alt: string; image: ImageMetadata };
};

const { title, spotlight } = Astro.props;
---

<div class="flip-card">
  <div class="front">
    <img src={spotlight.image.src} alt={spotlight.alt} />
    <h3>{title}</h3>
  </div>
  <div class="back">
    <h3>{title}</h3>
    <slot />
  </div>
</div>

<style>
  .flip-card {
    display: grid;
    justify-items: center;
    perspective: 1000px;
  }

  .front,
  .back {
    width: 60%;
    height: 20rem;
    grid-area: 1 / 1;
    backface-visibility: hidden;
    transition: transform 0.6s;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--size-gap);
    border-radius: var(--size-border-radius-large);
    border: var(--border-massive);
  }

  img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    border-radius: var(--size-border-radius-small);
  }

  .front {
    background-color: var(--color-white-97);
  }

  .back {
    background-color: var(--color-primary);
    color: var(--color-white);
    transform: rotateY(180deg);
    justify-content: flex-start;
    overflow-y: auto;
  }

  @media (hover: hover) {
    .flip-card:hover .front {
      transform: rotateY(180deg);
    }

    .flip-card:hover .back {
      transform: rotateY(360deg);
    }
  }

  .flip-card.flipped .front {
    transform: rotateY(180deg);
  }

  .flip-card.flipped .back {
    transform: rotateY(360deg);
  }
</style>

<script>
  if (window.matchMedia("(hover: none)").matches) {
    document.querySelectorAll<HTMLElement>(".flip-card").forEach((card) => {
      card.addEventListener("click", () => card.classList.toggle("flipped"));
    });
  }
</script>
