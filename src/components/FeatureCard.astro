---
type Props = {
  title: string;
  titleLevel?: "h2" | "h3" | "h4" | "h5" | "h6";
};

const { title, titleLevel: TitleTag = "h4" } = Astro.props;
---

<div class="feature-card">
  <div class="front">
    <div class="icon-wrapper">
      <slot name="icon" />
    </div>
    <TitleTag>{title}</TitleTag>
    <slot />
  </div>

  <div class="back">
    <TitleTag>{title}</TitleTag>
    <slot name="back" />
  </div>
</div>

<style>
  .feature-card {
    display: grid;
    grid-template-columns: auto;
    justify-items: center;
    perspective: 1000px;
    margin: var(--size-gap) var(--size-gap-huge);
  }

  .front,
  .back {
    width: 100%;
    height: 12rem;
    grid-area: 1 / 1;
    backface-visibility: hidden;
    transition: transform 0.6s;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: var(--size-gap-large);
    border-radius: var(--size-border-radius-large);
    border: var(--border-massive);
    gap: var(--size-gap-small);
    word-break: normal;
    cursor: pointer;
  }

  .front {
    position: relative;
    background-color: var(--color-white-97);
    display: grid;
    grid-template-rows: auto auto 1fr;
    align-content: flex-start;
    justify-items: center;
    gap: var(--size-gap);
  }

  .front :global(p),
  .front :global(h4),
  .back :global(p),
  .back :global(h4) {
    margin: 0;
  }

  .back :global(p) {
    margin: 0;
  }

  .icon-wrapper :global(svg) {
    width: 2rem;
    height: auto;
  }

  .front::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    clip-path: polygon(100% 0, 100% 100%, 0 100%);
  }

  .back {
    background-color: var(--color-primary);
    color: var(--color-white);
    transform: rotateY(180deg);
    justify-content: flex-start;
    gap: var(--size-gap);
    overflow-y: auto;
  }

  .feature-card.flipped .front {
    transform: rotateY(180deg);
  }

  .feature-card.flipped .back {
    transform: rotateY(360deg);
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const cards = document.querySelectorAll(".feature-card");
    const card = e.target instanceof Element ? e.target.closest(".feature-card") : null;
    const isOpen = card?.classList.contains("flipped");

    cards.forEach((c) => c.classList.remove("flipped"));

    if (card && !isOpen) {
      card.classList.add("flipped");
    }
  });
</script>
