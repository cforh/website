---
const { headers = [], rows = [] } = Astro.props;
---

<table>
  <thead>
    <tr>
      {headers.map((header) => <th>{header}</th>)}
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          {row.map((cell, index) => (
            <td>{index === 0 ? <strong>{cell}</strong> : cell}</td>
          ))}
        </tr>
      ))
    }
  </tbody>
</table>

<style>
  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    padding: var(--size-gap-small) var(--size-gap-medium);
    text-align: left;
  }

  thead th {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  tbody tr:nth-child(odd) {
    background-color: rgb(from var(--color-primary) r g b / 0.12);
  }

  tbody tr:nth-child(even) {
    background-color: rgb(from var(--color-primary) r g b / 0.06);
  }
</style>
