---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

type Props = {
  image: ImageMetadata;
  primaryColor: string;
  secondaryColor: string;
};

const { image, primaryColor, secondaryColor, ...rest } = Astro.props;
const gradientId = `grad-${Math.random().toString(36).substring(7)}`;
---

<div class="icon-cover" {...rest}>
  <Image src={image} alt="Cover image" />
  <svg class="gradient-overlay" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none">
    <defs>
      <radialGradient id={gradientId} cx="50%" cy="50%" r="50%">
        <stop offset="0%" style={`stop-color:${primaryColor};stop-opacity:0.6`}></stop>
        <stop offset="100%" style={`stop-color:${secondaryColor};stop-opacity:0.3`}></stop>
      </radialGradient>
      <filter id="fractalNoise">
        <feTurbulence type="fractalNoise" baseFrequency="0.5" numOctaves="5" result="noise" stitchTiles="stitch"
        ></feTurbulence>
        <feBlend in="SourceGraphic" in2="noise" mode="multiply"></feBlend>
        <feColorMatrix in="noisy" type="saturate" values="1"></feColorMatrix>
      </filter>
    </defs>
    <rect width="100" height="100" fill={`url(#${gradientId})`} filter="url(#fractalNoise)"></rect>
  </svg>
</div>

<style>
  .icon-cover {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .icon-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gradient-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>
