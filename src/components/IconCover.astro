---
import { Image } from "astro:assets";
import type { ImageAsset } from "../types";

type Props = {
  image: ImageAsset;
  primaryColor: string;
  secondaryColor: string;
};

const { image, primaryColor, secondaryColor, ...rest } = Astro.props;
const gradientId = `grad-${Math.random().toString(36).substring(7)}`;
const filterId = `noise-${Math.random().toString(36).substring(7)}`;
---

<div class="icon-cover" {...rest}>
  <svg class="gradient-overlay" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id={gradientId} x1="100%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" style={`stop-color:${primaryColor};stop-opacity:0.7`}></stop>
        <stop offset="100%" style={`stop-color:${secondaryColor};stop-opacity:0.4`}></stop>
      </linearGradient>
      <filter id={filterId}>
        <feTurbulence type="fractalNoise" baseFrequency="0.5" numOctaves="5" result="noise" stitchTiles="stitch"
        ></feTurbulence>
        <feBlend in="SourceGraphic" in2="noise" mode="multiply"></feBlend>
        <feColorMatrix in="noisy" type="saturate" values="1"></feColorMatrix>
      </filter>
    </defs>
    <rect width="100%" height="100%" fill={`url(#${gradientId})`} filter={`url(#${filterId})`}></rect>
  </svg>
  <div class="icon-foreground">
    <Image src={image.image} alt={image.alt} />
  </div>
</div>

<style>
  .icon-cover {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .icon-foreground {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .icon-cover :global(img) {
    width: auto;
    height: 50%;
    object-fit: cover;
    display: block;
    filter: drop-shadow(0 0 40px var(--color-white)) drop-shadow(0 0 10px var(--color-white))
      drop-shadow(0 0 5px var(--color-white));
  }

  .gradient-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
